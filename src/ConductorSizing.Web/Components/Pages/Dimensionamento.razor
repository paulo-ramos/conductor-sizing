@page "/dimensionamento"
@rendermode InteractiveServer
@using ConductorSizing.Application.Services
@using ConductorSizing.Domain.Models
@using ConductorSizing.Domain.Enums
@using ConductorSizing.Domain.Interfaces
@using ConductorSizing.Web.Models
@using ConductorSizing.Infrastructure.Reports
@using Microsoft.JSInterop
@inject IDimensionamentoService DimensionamentoService
@inject IJSRuntime JSRuntime

<PageTitle>Dimensionamento - Conductor Sizing</PageTitle>

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Dimensionamento de Condutores</h1>
        <p class="text-gray-600">Preencha os dados do circuito para calcular a bitola adequada conforme NBR 5410:2004</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
        <!-- Form Section -->
        <div class="space-y-6">
            <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
                <!-- Card Header -->
                <div class="bg-gradient-primary px-6 py-4">
                    <h2 class="text-xl font-semibold text-white flex items-center">
                        <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Dados de Entrada
                    </h2>
                </div>

                <!-- Card Body -->
                <div class="p-6">
                    <EditForm Model="@_entrada" OnValidSubmit="@CalcularDimensionamento" class="space-y-5">
                        <!-- Identificação -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Identificação do Circuito</label>
                            <InputText @bind-Value="_entrada.IdentificacaoCircuito" 
                                       class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
                                       placeholder="Ex: Circuito 5 - Ar-Condicionado 12.000 BTU" />
                        </div>

                        <!-- Potência e Tensão -->
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Potência (W)</label>
                                <InputNumber @bind-Value="_entrada.PotenciaAtivaWatts" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Tensão (V)</label>
                                <InputNumber @bind-Value="_entrada.TensaoVolts" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                        </div>

                        <!-- Comprimento, FP e Rendimento -->
                        <div class="grid md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Comprimento (m)</label>
                                <InputNumber @bind-Value="_entrada.ComprimentoMetros" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Fator de Potência</label>
                                <InputNumber @bind-Value="_entrada.FatorPotencia" 
                                            step="0.01"
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Rendimento</label>
                                <InputNumber @bind-Value="_entrada.Rendimento" 
                                            step="0.01"
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                        </div>

                        <!-- Metal e Isolação -->
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Metal</label>
                                <InputSelect @bind-Value="_entrada.TipoMetal" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all">
                                    <option value="@TipoMetal.Cobre">Cobre</option>
                                    <option value="@TipoMetal.Aluminio">Alumínio</option>
                                </InputSelect>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Isolação</label>
                                <InputSelect @bind-Value="_entrada.TipoIsolacao" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all">
                                    <option value="@TipoIsolacao.PVC">PVC (70°C)</option>
                                    <option value="@TipoIsolacao.XLPE_EPR">XLPE/EPR (90°C)</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- Método e Condutores -->
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Método de Instalação</label>
                                <InputText @bind-Value="_entrada.MetodoInstalacao" 
                                          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
                                          placeholder="B1, A1, C, D..." />
                                <p class="text-xs text-gray-500 mt-1">Conforme Tabelas 36/37</p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Condutores Carregados</label>
                                <InputSelect @bind-Value="_entrada.NumeroCondutoresCarregados" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all">
                                    <option value="2">2 (Monofásico)</option>
                                    <option value="3">3 (Trifásico)</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- Temperatura e Agrupamento -->
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Temperatura (°C)</label>
                                <InputNumber @bind-Value="_entrada.TemperaturaAmbienteCelsius" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Circuitos Agrupados</label>
                                <InputNumber @bind-Value="_entrada.NumeroCircuitosAgrupados" 
                                            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all" />
                            </div>
                        </div>

                        <!-- Tipo de Linha -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Linha</label>
                            <InputSelect @bind-Value="_entrada.TipoLinha" 
                                        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all">
                                <option value="@TipoLinha.NaoSubterranea">Não Subterrânea</option>
                                <option value="@TipoLinha.Subterranea">Subterrânea</option>
                            </InputSelect>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" 
                                class="w-full px-6 py-4 gradient-primary text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-200 flex items-center justify-center">
                            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                            Calcular Dimensionamento
                        </button>

                        <!-- Error Message -->
                        @if (!string.IsNullOrEmpty(_erroMensagem))
                        {
                            <div class="p-4 bg-red-50 border border-red-200 rounded-xl flex items-start">
                                <svg class="w-5 h-5 text-red-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                </svg>
                                <div class="flex-1">
                                    <h4 class="text-sm font-semibold text-red-800 mb-1">Erro</h4>
                                    <p class="text-sm text-red-700">@_erroMensagem</p>
                                </div>
                            </div>
                        }
                    </EditForm>
                </div>
            </div>
        </div>

        <!-- Result Section -->
        <div>
            @if (_resultado != null)
            {
                <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
                    <!-- Result Header -->
                    <div class="@(_resultado.Aprovado ? "gradient-success" : "gradient-danger") px-6 py-4">
                        <h2 class="text-xl font-semibold text-white flex items-center">
                            @if (_resultado.Aprovado)
                            {
                                <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                </svg>
                                <span>APROVADO - Atende NBR 5410</span>
                            }
                            else
                            {
                                <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                </svg>
                                <span>REPROVADO - Não atende critérios</span>
                            }
                        </h2>
                    </div>

                    <div class="p-6 space-y-6">
                        <!-- Resultado Principal -->
                        <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-xl p-6 border-2 border-primary-200">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4 text-center">Resultado Final</h3>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="text-center">
                                    <p class="text-sm text-gray-600 mb-1">Condutor Fase</p>
                                    <p class="text-4xl font-bold text-primary-600">@_resultado.SecaoNominalFase</p>
                                    <p class="text-sm text-gray-500">mm²</p>
                                </div>
                                <div class="text-center">
                                    <p class="text-sm text-gray-600 mb-1">Condutor PE</p>
                                    <p class="text-4xl font-bold text-green-600">@_resultado.SecaoNominalPE</p>
                                    <p class="text-sm text-gray-500">mm²</p>
                                </div>
                            </div>
                        </div>

                        <!-- Cálculos Detalhados -->
                        <div>
                            <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center">
                                <svg class="w-5 h-5 mr-2 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                </svg>
                                Cálculos Técnicos
                            </h3>
                            <div class="space-y-2">
                                <div class="flex justify-between py-2 border-b border-gray-200">
                                    <span class="text-gray-700">Corrente de Projeto (Ib)</span>
                                    <span class="font-semibold text-gray-900">@_resultado.CorrenteProjetoIb.ToString("F2") A</span>
                                </div>
                                <div class="flex justify-between py-2 border-b border-gray-200">
                                    <span class="text-gray-700">FCT (Temperatura)</span>
                                    <span class="font-semibold text-gray-900">@_resultado.FatorCorrecaoTemperatura.ToString("F3")</span>
                                </div>
                                <div class="flex justify-between py-2 border-b border-gray-200">
                                    <span class="text-gray-700">FCA (Agrupamento)</span>
                                    <span class="font-semibold text-gray-900">@_resultado.FatorCorrecaoAgrupamento.ToString("F3")</span>
                                </div>
                                <div class="flex justify-between py-2 border-b border-gray-200">
                                    <span class="text-gray-700">Iz (Cap. Tabela)</span>
                                    <span class="font-semibold text-gray-900">@_resultado.CapacidadeTabelaIz.ToString("F2") A</span>
                                </div>
                                <div class="flex justify-between py-2 border-b border-gray-200">
                                    <span class="text-gray-700">Iz' (Cap. Corrigida)</span>
                                    <span class="font-semibold text-gray-900">@_resultado.CapacidadeCorrigidaIzLinha.ToString("F2") A</span>
                                </div>
                                <div class="flex justify-between py-2 @(_resultado.QuedaTensaoPercentual > 4.0 ? "bg-red-50" : "bg-green-50") rounded-lg px-3">
                                    <span class="@(_resultado.QuedaTensaoPercentual > 4.0 ? "text-red-700" : "text-green-700") font-medium">Queda de Tensão (ΔU)</span>
                                    <span class="@(_resultado.QuedaTensaoPercentual > 4.0 ? "text-red-900" : "text-green-900") font-bold">@_resultado.QuedaTensaoPercentual.ToString("F2")%</span>
                                </div>
                            </div>
                        </div>

                        <!-- Mensagens -->
                        @if (_resultado.Mensagens.Any())
                        {
                            <div>
                                <h3 class="text-lg font-semibold text-gray-800 mb-3">Observações</h3>
                                <div class="space-y-2">
                                    @foreach (var mensagem in _resultado.Mensagens)
                                    {
                                        <div class="flex items-start p-3 bg-gray-50 rounded-lg border border-gray-200">
                                            <svg class="w-5 h-5 text-primary-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                                            </svg>
                                            <p class="text-sm text-gray-700">@mensagem</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Action Buttons -->
                        <div class="flex gap-3">
                            <button @onclick="LimparFormulario" 
                                    class="flex-1 px-4 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition-colors duration-200">
                                Nova Consulta
                            </button>
                            <button @onclick="GerarPDF" 
                                    class="flex-1 px-4 py-3 gradient-primary text-white font-semibold rounded-xl hover:shadow-lg transition-all duration-200 flex items-center justify-center">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Gerar PDF
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="bg-white rounded-2xl shadow-lg border-2 border-dashed border-gray-300 p-12 text-center">
                    <div class="flex flex-col items-center">
                        <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-700 mb-2">Aguardando Cálculo</h3>
                        <p class="text-gray-500">Preencha os dados e clique em "Calcular" para ver o resultado</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private DadosEntradaForm _entrada = new()
    {
        IdentificacaoCircuito = "Circuito 5 - Ar-Condicionado 12.000 BTU",
        PotenciaAtivaWatts = 1320.0,
        TensaoVolts = 220.0,
        ComprimentoMetros = 25.0,
        FatorPotencia = 0.92,
        Rendimento = 0.85,
        TipoMetal = TipoMetal.Cobre,
        TipoIsolacao = TipoIsolacao.PVC,
        MetodoInstalacao = "B1",
        NumeroCondutoresCarregados = 2,
        TemperaturaAmbienteCelsius = 35,
        NumeroCircuitosAgrupados = 3,
        TipoLinha = TipoLinha.NaoSubterranea,
        ResistividadeTermicaSoloKmW = null
    };
    private ResultadoDimensionamento? _resultado;
    private string? _erroMensagem;

    private void InicializarValoresPadrao()
    {
        _entrada = new DadosEntradaForm
        {
            IdentificacaoCircuito = "Circuito 5 - Ar-Condicionado 12.000 BTU",
            PotenciaAtivaWatts = 1320.0,
            TensaoVolts = 220.0,
            ComprimentoMetros = 25.0,
            FatorPotencia = 0.92,
            Rendimento = 0.85,
            TipoMetal = TipoMetal.Cobre,
            TipoIsolacao = TipoIsolacao.PVC,
            MetodoInstalacao = "B1",
            NumeroCondutoresCarregados = 2,
            TemperaturaAmbienteCelsius = 35,
            NumeroCircuitosAgrupados = 3,
            TipoLinha = TipoLinha.NaoSubterranea,
            ResistividadeTermicaSoloKmW = null
        };
    }

    private void CalcularDimensionamento()
    {
        try
        {
            _erroMensagem = null;
            
            // Validar dados antes de converter
            if (string.IsNullOrWhiteSpace(_entrada.MetodoInstalacao))
            {
                _erroMensagem = "Método de instalação é obrigatório.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_entrada.IdentificacaoCircuito))
            {
                _erroMensagem = "Identificação do circuito é obrigatória.";
                return;
            }

            if (_entrada.PotenciaAtivaWatts <= 0 || _entrada.TensaoVolts <= 0 || _entrada.ComprimentoMetros <= 0)
            {
                _erroMensagem = "Potência, Tensão e Comprimento devem ser maiores que zero.";
                return;
            }

            if (_entrada.FatorPotencia <= 0 || _entrada.FatorPotencia > 1)
            {
                _erroMensagem = "Fator de Potência deve estar entre 0 e 1.";
                return;
            }

            if (_entrada.Rendimento <= 0 || _entrada.Rendimento > 1)
            {
                _erroMensagem = "Rendimento deve estar entre 0 e 1.";
                return;
            }

            if (_entrada.NumeroCondutoresCarregados != 2 && _entrada.NumeroCondutoresCarregados != 3)
            {
                _erroMensagem = "Número de condutores carregados deve ser 2 ou 3.";
                return;
            }

            if (_entrada.TemperaturaAmbienteCelsius < -20 || _entrada.TemperaturaAmbienteCelsius > 80)
            {
                _erroMensagem = "Temperatura ambiente deve estar entre -20°C e 80°C.";
                return;
            }

            if (_entrada.NumeroCircuitosAgrupados < 1)
            {
                _erroMensagem = "Número de circuitos agrupados deve ser no mínimo 1.";
                return;
            }

            // Converter DadosEntradaForm (mutável) para DadosEntrada (record imutável)
            var dados = new DadosEntrada
            {
                IdentificacaoCircuito = _entrada.IdentificacaoCircuito,
                PotenciaAtivaWatts = _entrada.PotenciaAtivaWatts,
                TensaoVolts = _entrada.TensaoVolts,
                ComprimentoMetros = _entrada.ComprimentoMetros,
                FatorPotencia = _entrada.FatorPotencia,
                Rendimento = _entrada.Rendimento,
                TipoMetal = _entrada.TipoMetal,
                TipoIsolacao = _entrada.TipoIsolacao,
                MetodoInstalacao = _entrada.MetodoInstalacao,
                NumeroCondutoresCarregados = _entrada.NumeroCondutoresCarregados,
                TemperaturaAmbienteCelsius = _entrada.TemperaturaAmbienteCelsius,
                NumeroCircuitosAgrupados = _entrada.NumeroCircuitosAgrupados,
                TipoLinha = _entrada.TipoLinha,
                ResistividadeTermicaSoloKmW = _entrada.ResistividadeTermicaSoloKmW
            };
            
            // Executar o dimensionamento
            _resultado = DimensionamentoService.Calcular(dados);
        }
        catch (Exception ex)
        {
            _erroMensagem = $"Erro ao calcular dimensionamento: {ex.Message}";
            Console.WriteLine($"Erro detalhado: {ex}");
        }
    }

    private async Task GerarPDF()
    {
        if (_resultado == null) return;

        try
        {
            // Gerar o PDF em bytes
            var pdfBytes = RelatorioCondutorPDF.GerarBytes(_resultado);
            
            // Nome do arquivo
            var nomeArquivo = $"Dimensionamento_{_resultado.IdentificacaoCircuito.Replace(" ", "_")}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            
            // Enviar para o navegador para download
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", nomeArquivo, pdfBytes);
        }
        catch (Exception ex)
        {
            _erroMensagem = $"Erro ao gerar PDF: {ex.Message}";
            Console.WriteLine($"Erro ao gerar PDF: {ex}");
        }
    }

    private void LimparFormulario()
    {
        _resultado = null;
        _erroMensagem = null;
        InicializarValoresPadrao();
    }
}
